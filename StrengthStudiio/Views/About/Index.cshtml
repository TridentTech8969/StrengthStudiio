@{
    ViewData["Title"] = "About Us";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-white">About Strength Studio</h1>
                <p class="lead text-white">Your premier fitness destination in Bengaluru</p>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-6">
                <h2 class="display-5 fw-bold mb-4">Our Story</h2>
                <p class="lead text-muted mb-4">
                    Founded in 2020, Strength Studio Gym has been at the forefront of the fitness revolution in Belgaum. What started as a small community gym has grown into a comprehensive fitness center serving over 200+ members.
                </p>
                <p class="mb-4">
                    Our mission is simple: to create a welcoming, supportive environment where people of all fitness levels can achieve their health and wellness goals. We believe that fitness is not just about physical transformation, but about building confidence, community, and a healthier lifestyle.
                </p>
                <p class="mb-4">
                    With state-of-the-art equipment, expert trainers, and a variety of programs, we're committed to helping you become the best version of yourself.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="about-image">
                    <div class="placeholder-image-large">
                        <i class="fas fa-dumbbell fa-5x text-warning"></i>
                        <p class="text-muted mt-3">Modern Gym Facility</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission Vision Values -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="mvv-card text-center">
                    <div class="mvv-icon">
                        <i class="fas fa-bullseye"></i>
                    </div>
                    <h3>Our Mission</h3>
                    <p class="text-muted">
                        To empower individuals to achieve their fitness goals through expert guidance, modern facilities, and a supportive community that encourages personal growth and wellness.
                    </p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="mvv-card text-center">
                    <div class="mvv-icon">
                        <i class="fas fa-eye"></i>
                    </div>
                    <h3>Our Vision</h3>
                    <p class="text-muted">
                        To be the leading fitness center in Bengaluru, known for transforming lives and building a healthier, stronger community through innovative fitness solutions.
                    </p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="mvv-card text-center">
                    <div class="mvv-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h3>Our Values</h3>
                    <p class="text-muted">
                        Excellence in service, integrity in our approach, inclusivity for all fitness levels, and commitment to helping every member achieve lasting results.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Achievements Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Our Achievements</h2>
            <p class="lead text-muted">Numbers that speak for our commitment to excellence</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="achievement-card">
                    <div class="achievement-number">00+</div>
                    <div class="achievement-label">Happy Members</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="achievement-card">
                    <div class="achievement-number">15+</div>
                    <div class="achievement-label">Expert Trainers</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="achievement-card">
                    <div class="achievement-number">5+</div>
                    <div class="achievement-label">Years Experience</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="achievement-card">
                    <div class="achievement-number">98%</div>
                    <div class="achievement-label">Satisfaction Rate</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Facilities Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">World-Class Facilities</h2>
            <p class="lead text-muted">Everything you need for a complete fitness experience</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-dumbbell"></i>
                    </div>
                    <h5>Weight Training Area</h5>
                    <p class="text-muted">Complete range of free weights and resistance machines</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-running"></i>
                    </div>
                    <h5>Cardio Zone</h5>
                    <p class="text-muted">Modern treadmills, ellipticals, and bikes with entertainment systems</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h5>Group Class Studio</h5>
                    <p class="text-muted">Spacious studio for yoga, pilates, zumba, and HIIT classes</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-spa"></i>
                    </div>
                    <h5>Wellness Center</h5>
                    <p class="text-muted">Sauna, steam room, and recovery facilities</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-shower"></i>
                    </div>
                    <h5>Locker Rooms</h5>
                    <p class="text-muted">Clean, spacious changing rooms with modern amenities</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-car"></i>
                    </div>
                    <h5>Parking</h5>
                    <p class="text-muted">Ample parking space for members</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-wifi"></i>
                    </div>
                    <h5>Free WiFi</h5>
                    <p class="text-muted">High-speed internet throughout the facility</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-coffee"></i>
                    </div>
                    <h5>Juice Bar</h5>
                    <p class="text-muted">Fresh smoothies and healthy snacks</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Team Leadership -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Meet Our Leadership</h2>
            <p class="lead text-muted">The visionaries behind Strength Studio Gym</p>
        </div>
        <div class="row justify-content-center g-4">
            <div class="col-lg-4 col-md-6">
                <div class="leader-card">
                    <div class="leader-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                    </div>
                    <div class="leader-info">
                        <h4>Amit Sharma</h4>
                        <p class="leader-title text-warning">Founder & CEO</p>
                        <p class="text-muted">
                            Former fitness competitor with 15+ years in the industry. Passionate about making fitness accessible to everyone.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="leader-card">
                    <div class="leader-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                    </div>
                    <div class="leader-info">
                        <h4>Kavitha Nair</h4>
                        <p class="leader-title text-warning">Head of Operations</p>
                        <p class="text-muted">
                            MBA with specialization in health management. Ensures smooth operations and exceptional member experience.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>