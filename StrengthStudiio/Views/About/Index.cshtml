<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-white">About Strength Studio</h1>
                <p class="lead text-white-50">Your premier fitness destination in Belgaum</p>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section class="py-5" style="background-color: #0f0f0f;">
    <div class="container">
        <div class="row align-items-center mb-5 g-5">
            <div class="col-lg-6 order-2 order-lg-1">
                <div style="animation: fadeInLeft 1s ease-out;">
                    <h2 class="display-5 fw-bold text-white mb-4">Our Story</h2>
                    <p class="lead text-white-50 mb-4">
                        Founded in 2024, Strength Studio Gym has been at the forefront of the fitness revolution in Belgaum. What started as a small community gym has grown into a comprehensive fitness center serving over 750+ members.
                    </p>
                    <p class="text-white-50 mb-4">
                        Our mission is simple: to create a welcoming, supportive environment where people of all fitness levels can achieve their health and wellness goals. We believe that fitness is not just about physical transformation, but about building confidence, community, and a healthier lifestyle.
                    </p>
                    <p class="text-white-50 mb-4">
                        With state-of-the-art equipment, expert trainers, and a variety of programs, we're committed to helping you become the best version of yourself.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <div class="stat-badge" style="background: linear-gradient(145deg, #2d2d2d, #1a1a1a); padding: 1rem 1.5rem; border-radius: 10px; border: 1px solid #3d3d3d;">
                            <div class="text-warning fw-bold" style="font-size: 1.5rem;">2024</div>
                            <div class="text-white-50 small">Est. Year</div>
                        </div>
                        <div class="stat-badge" style="background: linear-gradient(145deg, #2d2d2d, #1a1a1a); padding: 1rem 1.5rem; border-radius: 10px; border: 1px solid #3d3d3d;">
                            <div class="text-warning fw-bold" style="font-size: 1.5rem;">750+</div>
                            <div class="text-white-50 small">Members</div>
                        </div>
                        <div class="stat-badge" style="background: linear-gradient(145deg, #2d2d2d, #1a1a1a); padding: 1rem 1.5rem; border-radius: 10px; border: 1px solid #3d3d3d;">
                            <div class="text-warning fw-bold" style="font-size: 1.5rem;">5+</div>
                            <div class="text-white-50 small">Trainers</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 order-1 order-lg-2">
                <div class="about-image" style="animation: fadeInRight 1s ease-out;">
                    <div class="placeholder-image-large" style="background: linear-gradient(145deg, #2d2d2d, #1a1a1a); border: 2px solid #3d3d3d; position: relative; overflow: hidden;">
                        <!-- Replace this img src with your actual gym photo -->
