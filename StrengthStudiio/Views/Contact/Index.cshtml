@{
    ViewData["Title"] = "Contact";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-white">Contact Us</h1>
                <p class="lead text-white-50">Get in touch with our team - we're here to help</p>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section class="py-5" style="background-color: #0f0f0f;">
    <div class="container">
        <div class="row g-4">
            <!-- Contact Form -->
            <div class="col-lg-8">
                <div class="contact-form-card">
                    <div class="d-flex align-items-center mb-4">
                        <div class="contact-icon me-3" style="width: 60px; height: 60px;">
                            <i class="fas fa-paper-plane"></i>
                        </div>
                        <div>
                            <h2 class="text-white fw-bold mb-1">Send us a Message</h2>
                            <p class="text-white-50 mb-0">We'll get back to you within 24 hours</p>
                        </div>
                    </div>
                    <form id="contactForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="firstName" class="form-label">First Name *</label>
                                <input type="text" class="form-control" id="firstName" placeholder="John" required>
                            </div>
                            <div class="col-md-6">
                                <label for="lastName" class="form-label">Last Name *</label>
                                <input type="text" class="form-control" id="lastName" placeholder="Doe" required>
                            </div>
                            <div class="col-md-6">
                                <label for="email" class="form-label">Email Address *</label>
                                <input type="email" class="form-control" id="email" placeholder="john@example.com" required>
                            </div>
                            <div class="col-md-6">
                                <label for="phone" class="form-label">Phone Number *</label>
                                <input type="tel" class="form-control" id="phone" placeholder="+91 98765 43210" required>
                            </div>
                            <div class="col-12">
                                <label for="service" class="form-label">I'm interested in</label>
                                <select class="form-select" id="service">
                                    <option value="">Select a service</option>
                                    <option value="membership">Gym Membership</option>
                                    <option value="personal-training">Personal Training</option>
                                    <option value="group-classes">Group Classes</option>
                                    <option value="nutrition">Nutrition Counseling</option>
                                    <option value="corporate">Corporate Wellness</option>
                                    <option value="trial">Free Trial Session</option>
                                    <option value="other">Other Inquiry</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label for="message" class="form-label">Your Message *</label>
                                <textarea class="form-control" id="message" rows="5" placeholder="Tell us about your fitness goals and how we can help you achieve them..." required></textarea>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="newsletter">
                                    <label class="form-check-label text-white-50" for="newsletter">
                                        <i class="fas fa-envelope-open-text text-warning me-2"></i>
                                        Subscribe to our newsletter for fitness tips, workout plans, and exclusive offers
                                    </label>
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-warning btn-lg px-5 py-3 fw-bold w-100 w-md-auto" style="border-radius: 10px;">
                                    <i class="fas fa-paper-plane me-2"></i> Send Message
                                </button>
                                <p class="text-white-50 small mt-3 mb-0">
                                    <i class="fas fa-lock me-1"></i> Your information is secure and will never be shared
                                </p>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Contact Info -->
            <div class="col-lg-4">
                <div class="contact-info">
                    <h3 class="text-white fw-bold mb-4">Get in Touch</h3>

                    <!-- Visit Us -->
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div class="contact-details">
                            <h5>Visit Us</h5>
                            <p>
                                1789/1, Kelkar Bagh Rd,<br>
                                Kelkar Bagh, Raviwar Peth,<br>
                                Belagavi, Karnataka 590001
                            </p>
                            <a href="https://goo.gl/maps/YOUR_MAP_LINK" target="_blank" class="text-warning text-decoration-none">
                                <i class="fas fa-directions me-1"></i> Get Directions
                            </a>
                        </div>
                    </div>

                    <!-- Call Us -->
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div class="contact-details">
                            <h5>Call Us</h5>
                            <p>
                                <a href="tel:+917090029156" class="text-white-50 text-decoration-none">+91 7090029156</a><br>
                                <a href="tel:+918012345678" class="text-white-50 text-decoration-none">+91 80 1234 5678</a>
                            </p>
                            <p class="small text-warning mb-0">
                                <i class="fas fa-info-circle me-1"></i> Available during operating hours
                            </p>
                        </div>
                    </div>

                    <!-- Email Us -->
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="contact-details">
                            <h5>Email Us</h5>
                            <p>
                                <a href="mailto:info@strengthstudiogym.com" class="text-white-50 text-decoration-none">info@strengthstudiogym.com</a><br>
                                <a href="mailto:support@strengthstudiogym.com" class="text-white-50 text-decoration-none">support@strengthstudiogym.com</a>
                            </p>
                            <p class="small text-warning mb-0">
                                <i class="fas fa-reply me-1"></i> We respond within 24 hours
                            </p>
                        </div>
                    </div>

                    <!-- Operating Hours -->
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="contact-details">
                            <h5>Operating Hours</h5>
                            <div class="hours-list">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-white-50">Monday - Saturday</span>
                                </div>
                                <div class="mb-2">
                                    <span class="text-warning fw-bold">Morning:</span>
                                    <span class="text-white-50"> 5:00 AM - 11:00 AM</span>
                                </div>
                                <div class="mb-3">
                                    <span class="text-warning fw-bold">Evening:</span>
                                    <span class="text-white-50"> 4:00 PM - 10:00 PM</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-white-50">Sunday</span>
                                    <span class="text-danger fw-bold">Rest Day</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Social Media -->
                    <div class="mt-4 pt-4" style="border-top: 1px solid #3d3d3d;">
                        <h5 class="text-white fw-bold mb-3">Follow Us</h5>
                        <div class="social-icons d-flex gap-3 flex-wrap">
                            <a href="#" class="social-icon" title="Facebook">
                                <i class="fab fa-facebook-f"></i>
                            </a>
                            <a href="https://www.instagram.com/strengthstudiobelgaum/" class="social-icon" title="Instagram">
                                <i class="fab fa-instagram"></i>
                            </a>
                            <a href="#" class="social-icon" title="Twitter">
                                <i class="fab fa-twitter"></i>
                            </a>
                            <a href="#" class="social-icon" title="YouTube">
                                <i class="fab fa-youtube"></i>
                            </a>
                            <a href="#" class="social-icon" title="WhatsApp">
                                <i class="fab fa-whatsapp"></i>
                            </a>
                        </div>
                        <p class="text-white-50 small mt-3 mb-0">
                            <i class="fas fa-heart text-danger me-1"></i> Join our community of 750+ fitness enthusiasts
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Map Section -->
<section class="py-5" style="background-color: #1a1a1a;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-white mb-3">Find Us on Map</h2>
            <p class="lead text-white-50">Located in the heart of Belagavi - Easy to reach, ample parking</p>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="map-container" style="border-radius: 15px; overflow: hidden; border: 2px solid #3d3d3d; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3837.9396626157177!2d74.50632297459596!3d15.859768245012418!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bbf675ca1578ecd%3A0x86f3bc634a311c58!2sStrength%20Studio!5e0!3m2!1sen!2sin!4v1754308947587!5m2!1sen!2sin" 
                        width="100%" 
                        height="500" 
                        style="border:0;" 
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
                <div class="text-center mt-4">
                    <a href="https://maps.app.goo.gl/Bvk1ZTYKKbDmqR189" target="_blank" class="btn btn-outline-warning btn-lg px-5 py-3 fw-bold" style="border-radius: 10px; border-width: 2px;">
                        <i class="fas fa-directions me-2"></i> Open in Google Maps
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Contact CTA -->
<section class="cta-section py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <div class="d-flex align-items-center">
                    <div class="cta-icon" style="width: 70px; height: 70px; background: rgba(0, 0, 0, 0.3); border-radius: 15px; display: flex; align-items: center; justify-content: center; margin-right: 20px;">
                        <i class="fas fa-rocket text-white" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h3 class="text-white fw-bold mb-2">Ready to start your fitness journey?</h3>
                        <p class="text-white mb-0">Visit us today for a free consultation and gym tour!</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 text-lg-end text-center">
                <div class="d-flex gap-3 flex-wrap justify-content-lg-end justify-content-center">
                    <a href="tel:+917090029156" class="btn btn-dark btn-lg px-4 py-3 fw-bold" style="border-radius: 10px;">
                        <i class="fas fa-phone me-2"></i> Call Now
                    </a>
                    <a href="@Url.Action("Index", "Membership")" class="btn btn-outline-dark btn-lg px-4 py-3 fw-bold" style="border-radius: 10px; border-width: 2px; border-color: #000; color: #000;">
                        <i class="fas fa-id-card me-2"></i> Join Now
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="py-5" style="background-color: #0f0f0f;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-white mb-3">Common Questions</h2>
            <p class="lead text-white-50">Quick answers to questions you may have</p>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="contactFAQ">
                    <div class="accordion-item" style="background-color: #1a1a1a; border: 1px solid #3d3d3d; margin-bottom: 15px; border-radius: 10px; overflow: hidden;">
                        <h2 class="accordion-header">
                            <button class="accordion-button fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq1" style="background-color: #2d2d2d; color: #fff; border: none;">
                                Do you offer free trial sessions?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#contactFAQ">
                            <div class="accordion-body text-white-50" style="background-color: #1a1a1a;">
                                Yes! We offer a complimentary trial session so you can experience our facility and training approach. Contact us to schedule your free trial.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item" style="background-color: #1a1a1a; border: 1px solid #3d3d3d; margin-bottom: 15px; border-radius: 10px; overflow: hidden;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq2" style="background-color: #2d2d2d; color: #fff; border: none;">
                                Is parking available?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#contactFAQ">
                            <div class="accordion-body text-white-50" style="background-color: #1a1a1a;">
                                Yes, we have ample parking space available for all our members at no additional cost.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item" style="background-color: #1a1a1a; border: 1px solid #3d3d3d; margin-bottom: 15px; border-radius: 10px; overflow: hidden;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq3" style="background-color: #2d2d2d; color: #fff; border: none;">
                                Can I visit the gym before joining?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#contactFAQ">
                            <div class="accordion-body text-white-50" style="background-color: #1a1a1a;">
                                Absolutely! We encourage potential members to visit and take a tour of our facility. Contact us to schedule a visit at your convenience.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item" style="background-color: #1a1a1a; border: 1px solid #3d3d3d; margin-bottom: 15px; border-radius: 10px; overflow: hidden;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq4" style="background-color: #2d2d2d; color: #fff; border: none;">
                                What should I bring for my first visit?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#contactFAQ">
                            <div class="accordion-body text-white-50" style="background-color: #1a1a1a;">
                                Just bring comfortable workout clothes, athletic shoes, and a water bottle. We provide lockers and towels for all members.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Contact Form Enhancements */
    .contact-form-card {
        position: relative;
    }

    .contact-form-card::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        background: linear-gradient(135deg, #ff6b00, #ffa500);
        border-radius: 15px;
        opacity: 0.1;
        z-index: -1;
    }

    /* Form Validation Styles */
    .form-control:focus,
    .form-select:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.25rem rgba(255, 165, 0, 0.25);
    }

    .form-control.is-invalid {
        border-color: #dc3545;
    }

    .form-control.is-valid {
        border-color: var(--primary-color);
    }

    /* Contact Item Hover Effect */
    .contact-item {
        transition: transform 0.3s ease;
    }

    .contact-item:hover {
        transform: translateX(5px);
    }

    /* Map Responsive */
    @@media (max-width: 767.98px) {
        .map-container iframe {
            height: 350px !important;
        }

        .cta-section .d-flex {
            flex-direction: column;
            text-align: center;
        }

        .cta-icon {
            margin: 0 auto 15px !important;
        }
    }

    /* Hours List Styling */
    .hours-list {
        padding: 15px;
        background: rgba(255, 165, 0, 0.05);
        border-radius: 10px;
        border-left: 3px solid var(--primary-color);
    }

    /* Accordion Hover */
    .accordion-button:not(.collapsed) {
        background-color: var(--primary-color) !important;
        color: #000 !important;
    }

    .accordion-button:hover {
        background-color: #3d3d3d !important;
    }
</style>

<script>
    // Form Submission Handler
    document.getElementById('contactForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Get form values
        const firstName = document.getElementById('firstName').value;
        const lastName = document.getElementById('lastName').value;
        const email = document.getElementById('email').value;
        const phone = document.getElementById('phone').value;
        const service = document.getElementById('service').value;
        const message = document.getElementById('message').value;
        const newsletter = document.getElementById('newsletter').checked;
        
        // Here you would typically send this data to your backend
        // For now, we'll just show a success message
        
        alert('Thank you for contacting us! We will get back to you within 24 hours.');
        
        // Reset form
        this.reset();
    });

    // Form Validation
    const form = document.getElementById('contactForm');
    const inputs = form.querySelectorAll('input[required], textarea[required]');
    
    inputs.forEach(input => {
        input.addEventListener('blur', function() {
            if (this.value.trim() === '') {
                this.classList.add('is-invalid');
                this.classList.remove('is-valid');
            } else {
                this.classList.remove('is-invalid');
                this.classList.add('is-valid');
            }
        });
        
        input.addEventListener('input', function() {
            if (this.value.trim() !== '') {
                this.classList.remove('is-invalid');
                this.classList.add('is-valid');
            }
        });
    });

    // Email Validation
    const emailInput = document.getElementById('email');
    emailInput.addEventListener('blur', function() {
        const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        if (!emailRegex.test(this.value)) {
            this.classList.add('is-invalid');
            this.classList.remove('is-valid');
        } else {
            this.classList.remove('is-invalid');
            this.classList.add('is-valid');
        }
    });

    // Phone Validation
    const phoneInput = document.getElementById('phone');
    phoneInput.addEventListener('blur', function() {
        const phoneRegex = /^[+]?[\d\s-()]+$/;
        if (!phoneRegex.test(this.value) || this.value.length < 10) {
            this.classList.add('is-invalid');
            this.classList.remove('is-valid');
        } else {
            this.classList.remove('is-invalid');
            this.classList.add('is-valid');
        }
    });
</script>
