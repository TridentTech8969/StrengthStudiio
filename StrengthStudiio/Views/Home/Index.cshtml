@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->

<section class="hero-section">
    <div class="hero-overlay">
        <div class="container">
            <div class="row align-items-center min-vh-100">
                <div class="col-lg-6">
                    <h1 class="display-3 fw-bold text-white mb-4">
                        Transform Your <span class="text-warning">Body</span>
                       
                    </h1>
                    <h1>Anirudh Web</h1>
                    <p class="lead text-white mb-4">
                        Join FitZone Gym and discover the best version of yourself. State-of-the-art equipment, expert trainers, and a supportive community await you.
                    </p>
                    <div class="hero-buttons">
                        <a href="@Url.Action("Index", "Membership")" class="btn btn-warning btn-lg me-3">
                            <i class="fas fa-rocket"></i> Start Your Journey
                        </a>
                        <a href="@Url.Action("Index", "Services")" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-play-circle"></i> Learn More
                        </a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="hero-stats">
                        <div class="row g-4">
                            <div class="col-6">
                                <div class="stat-card">
                                    <h3 class="text-warning">500+</h3>
                                    <p>Happy Members</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card">
                                    <h3 class="text-warning">15+</h3>
                                    <p>Expert Trainers</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card">
                                    <h3 class="text-warning">50+</h3>
                                    <p>Equipment</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card">
                                    <h3 class="text-warning">5+</h3>
                                    <p>Years Experience</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col-lg-8 mx-auto">
                <h2 class="display-5 fw-bold mb-3">Why Choose FitZone?</h2>
                <p class="lead text-muted">We provide everything you need to achieve your fitness goals</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-dumbbell"></i>
                    </div>
                    <h4>Modern Equipment</h4>
                    <p class="text-muted">State-of-the-art fitness equipment from leading brands to ensure the best workout experience.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h4>Expert Trainers</h4>
                    <p class="text-muted">Certified personal trainers with years of experience to guide you every step of the way.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h4>Flexible Hours</h4>
                    <p class="text-muted">Open 7 days a week with extended hours to fit your busy schedule.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h4>Group Classes</h4>
                    <p class="text-muted">Energizing group fitness classes including yoga, pilates, zumba, and high-intensity training.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-spa"></i>
                    </div>
                    <h4>Wellness Center</h4>
                    <p class="text-muted">Complete wellness facility with sauna, steam room, and recovery services.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <h4>FitZone App</h4>
                    <p class="text-muted">Track your progress, book classes, and stay connected with our mobile app.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section py-5">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h2 class="display-5 fw-bold text-white mb-4">Ready to Start Your Fitness Journey?</h2>
                <p class="lead text-white mb-4">Join hundreds of satisfied members who have transformed their lives at FitZone Gym.</p>
                <a href="@Url.Action("Index", "Membership")" class="btn btn-warning btn-lg">
                    <i class="fas fa-arrow-right"></i> Get Membership Now
                </a>
            </div>
        </div>
    </div>
</section>