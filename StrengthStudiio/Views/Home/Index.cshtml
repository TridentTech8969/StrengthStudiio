@{
    ViewData["Title"] = "Best Gym in Belagavi | Expert Trainers & Modern Equipment";
    ViewData["MetaDescription"] = "Strength Studio is the best gym in Belagavi (Belgaum) with 750+ members, 5+ certified trainers & 50+ machines. Located at Kelkar Bagh Rd. Open Mon–Sat 5:30 AM–9 PM. Join today!";
    ViewData["MetaKeywords"] = "gym in Belagavi, best gym Belagavi, gym in Belgaum, best gym Belgaum, fitness center Belagavi, strength training Belagavi, personal trainer Belagavi, body building gym Belagavi, gym near me Belagavi, Strength Studio gym, gym membership Belagavi, weight loss gym Belgaum, women gym Belagavi, gym open 5:30 AM Belagavi";
    ViewData["CanonicalUrl"] = "https://strengthstudio.in/";
    ViewData["OgTitle"] = "Best Gym in Belagavi | Strength Studio — Expert Trainers & Modern Equipment";
    ViewData["OgDescription"] = "Join Belagavi's top gym — 750+ members, 5+ expert trainers, 50+ machines. Strength Studio at Kelkar Bagh Rd. Start your fitness journey today!";
    ViewData["OgImage"] = "https://strengthstudio.in/images/Gym-Equips/gym-dumbbells-rack.jpg";
    ViewData["OgImageAlt"] = "Main training floor at Strength Studio gym Belagavi with premium weight machines and free weights";
}

@section Head {
    <!-- Home Page Schema: WebSite -->
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "WebSite",
          "@@id": "https://strengthstudio.in/#website",
          "url": "https://strengthstudio.in/",
          "name": "Strength Studio Gym",
          "description": "Best gym in Belagavi, Karnataka with expert trainers and modern equipment",
          "publisher": { "@@id": "https://strengthstudio.in/#gym" },
          "inLanguage": "en-IN"
        }
    </script>

    <!-- Home Page Schema: FAQPage (shows rich results in Google) -->
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "FAQPage",
          "mainEntity": [
            {
              "@@type": "Question",
              "name": "What are the gym timings at Strength Studio Belagavi?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Strength Studio is open Monday to Saturday. Morning: 5:30 AM – 12:00 PM. Evening: 4:00 PM – 9:00 PM. Closed on Sundays."
              }
            },
            {
              "@@type": "Question",
              "name": "Where is Strength Studio Gym located in Belagavi?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Strength Studio Gym is located at 1789/1, Kelkar Bagh Road, Belagavi, Karnataka 590001."
              }
            },
            {
              "@@type": "Question",
              "name": "Does Strength Studio offer personal training in Belagavi?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Yes, Strength Studio has 5+ certified personal trainers who provide customized workout plans for weight loss, muscle gain and overall fitness."
              }
            },
            {
              "@@type": "Question",
              "name": "How many members does Strength Studio Gym have?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Strength Studio has 750+ happy members and has been serving the Belagavi fitness community for over 7 years."
              }
            },
            {
              "@@type": "Question",
              "name": "Is Strength Studio gym good for women in Belagavi?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Yes, Strength Studio is fully equipped for all members including women. We have dedicated cardio, functional training and strength zones. Female members are very welcome."
              }
            }
          ]
        }
    </script>

    <!-- Home Page Breadcrumb Schema -->
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "BreadcrumbList",
          "itemListElement": [
            { "@@type": "ListItem", "position": 1, "name": "Home", "item": "https://strengthstudio.in/" }
          ]
        }
    </script>
}

