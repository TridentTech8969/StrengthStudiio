@{
    ViewData["Title"] = "Membership";
}

<!-- Page Header -->
<section class="page-header" style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); padding: 100px 0 80px;">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-white mb-3">Membership Plans</h1>
                <p class="lead text-white-50">Choose the perfect plan for your fitness journey</p>
            </div>
        </div>
    </div>
</section>

<!-- Special Opening Offer Banner -->
<section class="py-4" style="background: linear-gradient(90deg, #ff6b00 0%, #ffa500 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h3 class="text-white mb-0 fw-bold">🎉 SPECIAL OFFER for all Members!</h3>
            </div>
            <div class="col-md-4 text-md-end">
                <span class="badge bg-dark text-warning fs-6 px-4 py-2">Limited Time</span>
            </div>
        </div>
    </div>
</section>

<!-- Opening Offer Plans -->
<section class="py-5" style="background-color: #0f0f0f;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-white mb-3">Opening Special Pricing</h2>
            <p class="lead text-white-50">Exclusive rates for all members</p>
        </div>
        <div class="row g-4 justify-content-center">
            <!-- 1 Year Special -->
            <div class="col-lg-3 col-md-6">
                <div class="opening-offer-card" style="background: linear-gradient(145deg, #1a1a1a 0%, #2d2d2d 100%); border: 2px solid #ffa500; border-radius: 15px; padding: 30px; text-align: center; height: 100%; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: #ff6b00; opacity: 0.1; border-radius: 50%;"></div>
                    <div class="duration-badge" style="background: #ffa500; color: #000; font-weight: bold; padding: 8px 20px; border-radius: 20px; display: inline-block; margin-bottom: 20px;">
                        1 YEAR
                    </div>
                    <div class="price-section mb-4">
                        <h2 class="text-warning fw-bold mb-0" style="font-size: 3rem;">₹8,000</h2>
                        <p class="text-white-50 mb-0">One-time payment</p>
                    </div>
                    <p class="text-white mb-4">Best value for committed fitness enthusiasts</p>
                    <a href="@Url.Action("Index", "Contact")" class="btn btn-warning w-100 fw-bold py-3" style="border-radius: 10px;">
                        Choose 1 Year
                    </a>
                </div>
            </div>

            <!-- 6 Months Special -->
            <div class="col-lg-3 col-md-6">
                <div class="opening-offer-card" style="background: linear-gradient(145deg, #1a1a1a 0%, #2d2d2d 100%); border: 2px solid #ffa500; border-radius: 15px; padding: 30px; text-align: center; height: 100%; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: #ff6b00; opacity: 0.1; border-radius: 50%;"></div>
                    <div class="duration-badge" style="background: #ffa500; color: #000; font-weight: bold; padding: 8px 20px; border-radius: 20px; display: inline-block; margin-bottom: 20px;">
                        6 MONTHS
                    </div>
                    <div class="price-section mb-4">
                        <h2 class="text-warning fw-bold mb-0" style="font-size: 3rem;">₹4,500</h2>
                        <p class="text-white-50 mb-0">One-time payment</p>
                    </div>
                    <p class="text-white mb-4">Perfect for building lasting habits</p>
                    <a href="@Url.Action("Index", "Contact")" class="btn btn-warning w-100 fw-bold py-3" style="border-radius: 10px;">
                        Choose 6 Months
                    </a>
                </div>
            </div>

            <!-- 3 Months Special -->
            <div class="col-lg-3 col-md-6">
                <div class="opening-offer-card" style="background: linear-gradient(145deg, #1a1a1a 0%, #2d2d2d 100%); border: 2px solid #ffa500; border-radius: 15px; padding: 30px; text-align: center; height: 100%; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: #ff6b00; opacity: 0.1; border-radius: 50%;"></div>
                    <div class="duration-badge" style="background: #ffa500; color: #000; font-weight: bold; padding: 8px 20px; border-radius: 20px; display: inline-block; margin-bottom: 20px;">
                        3 MONTHS
                    </div>
                    <div class="price-section mb-4">
                        <h2 class="text-warning fw-bold mb-0" style="font-size: 3rem;">₹2,500</h2>
                        <p class="text-success fw-bold mb-0">+ ₹500 Admission</p>
                    </div>
                    <p class="text-white mb-4">Great for testing the waters</p>
                    <a href="@Url.Action("Index", "Contact")" class="btn btn-warning w-100 fw-bold py-3" style="border-radius: 10px;">
                        Choose 3 Months
                    </a>
                </div>
            </div>

            <!-- 1 Month Special -->
            <div class="col-lg-3 col-md-6">
                <div class="opening-offer-card" style="background: linear-gradient(145deg, #1a1a1a 0%, #2d2d2d 100%); border: 2px solid #ffa500; border-radius: 15px; padding: 30px; text-align: center; height: 100%; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: #ff6b00; opacity: 0.1; border-radius: 50%;"></div>
                    <div class="duration-badge" style="background: #ffa500; color: #000; font-weight: bold; padding: 8px 20px; border-radius: 20px; display: inline-block; margin-bottom: 20px;">
                        1 MONTH
                    </div>
                    <div class="price-section mb-4">
                        <h2 class="text-warning fw-bold mb-0" style="font-size: 3rem;">₹1,000</h2>
                        <p class="text-success fw-bold mb-0">+ ₹1,000 Admission</p>
                    </div>
                    <p class="text-white mb-4">Flexible monthly option</p>
                    <a href="@Url.Action("Index", "Contact")" class="btn btn-warning w-100 fw-bold py-3" style="border-radius: 10px;">
                        Choose 1 Month
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>



<style>
    /* Hover Effects */
    .membership-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(255, 165, 0, 0.2);
    }

    .opening-offer-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(255, 165, 0, 0.3);
    }

    .benefit-card:hover {
        transform: translateY(-5px);
        border-color: #ffa500 !important;
        box-shadow: 0 10px 30px rgba(255, 165, 0, 0.2);
    }

    .annual-plan-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(255, 165, 0, 0.2);
    }

    /* Button Hover Effects */
    .btn-outline-warning:hover {
        background-color: #ffa500;
        color: #000;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 165, 0, 0.3);
    }

    .btn-warning:hover {
        background-color: #ff6b00;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(255, 165, 0, 0.4);
    }

    /* Accordion Hover */
    .accordion-button:not(.collapsed) {
        background-color: #ffa500 !important;
        color: #000 !important;
    }

    .accordion-button:hover {
        background-color: #3d3d3d !important;
    }
</style>
