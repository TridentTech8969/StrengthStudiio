@{
    ViewData["Title"] = "Services";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-white">Our Services</h1>
                <p class="lead text-white">Comprehensive fitness solutions tailored to your needs</p>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <!-- Personal Training -->
            <div class="col-lg-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <div class="service-content">
                        <h3>Personal Training</h3>
                        <p class="text-muted mb-3">One-on-one sessions with certified trainers tailored to your specific goals and fitness level.</p>
                        <ul class="service-features">
                            <li><i class="fas fa-check text-warning"></i> Customized workout plans</li>
                            <li><i class="fas fa-check text-warning"></i> Nutrition guidance</li>
                            <li><i class="fas fa-check text-warning"></i> Progress tracking</li>
                            <li><i class="fas fa-check text-warning"></i> Flexible scheduling</li>
                        </ul>
                        <div class="service-price">
                            <span class="price">₹2,500</span>
                            <span class="period">/session</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Group Classes -->
            <div class="col-lg-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="service-content">
                        <h3>Group Classes</h3>
                        <p class="text-muted mb-3">High-energy group fitness classes that make working out fun and social.</p>
                        <ul class="service-features">
                            <li><i class="fas fa-check text-warning"></i> Yoga & Pilates</li>
                            <li><i class="fas fa-check text-warning"></i> HIIT Training</li>
                            <li><i class="fas fa-check text-warning"></i> Zumba & Dance</li>
                            <li><i class="fas fa-check text-warning"></i> Spin Classes</li>
                        </ul>
                        <div class="service-price">
                            <span class="price">₹500</span>
                            <span class="period">/class</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Strength Training -->
            <div class="col-lg-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-dumbbell"></i>
                    </div>
                    <div class="service-content">
                        <h3>Strength Training</h3>
                        <p class="text-muted mb-3">Build muscle and increase strength with our comprehensive weight training programs.</p>
                        <ul class="service-features">
                            <li><i class="fas fa-check text-warning"></i> Free weights area</li>
                            <li><i class="fas fa-check text-warning"></i> Machine-guided workouts</li>
                            <li><i class="fas fa-check text-warning"></i> Powerlifting section</li>
                            <li><i class="fas fa-check text-warning"></i> Spotting assistance</li>
                        </ul>
                        <div class="service-price">
                            <span class="text-warning">Included</span>
                            <span class="period">in membership</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cardio Training -->
            <div class="col-lg-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <div class="service-content">
                        <h3>Cardio Training</h3>
                        <p class="text-muted mb-3">Improve cardiovascular health with our modern cardio equipment and programs.</p>
                        <ul class="service-features">
                            <li><i class="fas fa-check text-warning"></i> Treadmills & Ellipticals</li>
                            <li><i class="fas fa-check text-warning"></i> Stationary bikes</li>
                            <li><i class="fas fa-check text-warning"></i> Rowing machines</li>
                            <li><i class="fas fa-check text-warning"></i> Cardio circuits</li>
                        </ul>
                        <div class="service-price">
                            <span class="text-warning">Included</span>
                            <span class="period">in membership</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Nutrition Counseling -->
            <div class="col-lg-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-apple-alt"></i>
                    </div>
                    <div class="service-content">
                        <h3>Nutrition Counseling</h3>
                        <p class="text-muted mb-3">Professional nutrition guidance to complement your fitness journey.</p>
                        <ul class="service-features">
                            <li><i class="fas fa-check text-warning"></i> Meal planning</li>
                            <li><i class="fas fa-check text-warning"></i> Dietary assessments</li>
                            <li><i class="fas fa-check text-warning"></i> Supplement advice</li>
                            <li><i class="fas fa-check text-warning"></i> Weight management</li>
                        </ul>
                        <div class="service-price">
                            <span class="price">₹1,500</span>
                            <span class="period">/consultation</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recovery Services -->
            <div class="col-lg-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-spa"></i>
                    </div>
                    <div class="service-content">
                        <h3>Recovery Services</h3>
                        <p class="text-muted mb-3">Relax and recover with our wellness and recovery facilities.</p>
                        <ul class="service-features">
                            <li><i class="fas fa-check text-warning"></i> Sauna & Steam room</li>
                            <li><i class="fas fa-check text-warning"></i> Massage therapy</li>
                            <li><i class="fas fa-check text-warning"></i> Stretching area</li>
                            <li><i class="fas fa-check text-warning"></i> Ice baths</li>
                        </ul>
                        <div class="service-price">
                            <span class="price">₹800</span>
                            <span class="period">/session</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Schedule Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Class Schedule</h2>
            <p class="lead text-muted">Join our group classes throughout the week</p>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="schedule-table">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-dark">
                                <tr>
                                    <th>Time</th>
                                    <th>Monday</th>
                                    <th>Tuesday</th>
                                    <th>Wednesday</th>
                                    <th>Thursday</th>
                                    <th>Friday</th>
                                    <th>Saturday</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold">6:00 AM</td>
                                    <td class="yoga">Yoga</td>
                                    <td class="hiit">HIIT</td>
                                    <td class="yoga">Yoga</td>
                                    <td class="hiit">HIIT</td>
                                    <td class="yoga">Yoga</td>
                                    <td class="spin">Spin Class</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">7:30 AM</td>
                                    <td class="spin">Spin Class</td>
                                    <td class="pilates">Pilates</td>
                                    <td class="spin">Spin Class</td>
                                    <td class="pilates">Pilates</td>
                                    <td class="spin">Spin Class</td>
                                    <td class="zumba">Zumba</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">6:00 PM</td>
                                    <td class="zumba">Zumba</td>
                                    <td class="boxing">Boxing</td>
                                    <td class="zumba">Zumba</td>
                                    <td class="boxing">Boxing</td>
                                    <td class="zumba">Zumba</td>
                                    <td class="hiit">HIIT</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">
