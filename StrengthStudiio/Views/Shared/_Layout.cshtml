<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── Preconnect & DNS-Prefetch ── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="dns-prefetch" href="https://kit.fontawesome.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />
    <link rel="dns-prefetch" href="https://maps.googleapis.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- ── Site-wide Open Graph defaults (overridden per page) ── -->
    <meta property="og:site_name" content="Strength Studio Gym Belagavi" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_IN" />

    <!-- ── Twitter Card defaults ── -->
    <meta name="twitter:card" content="summary_large_image" />

    <!-- ── Geo Tags (local SEO) ── -->
    <meta name="geo.region" content="IN-KA" />
    <meta name="geo.placename" content="Belagavi, Karnataka, India" />
    <meta name="geo.position" content="15.8497;74.4977" />
    <meta name="ICBM" content="15.8497, 74.4977" />

    <!-- ── Mobile / PWA ── -->
    <meta name="theme-color" content="#ff6b00" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- ── Indexing ── -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />

    <!-- ── Author ── -->
    <meta name="author" content="Strength Studio Gym, Belagavi" />

    <!-- ── Per-page SEO: title, description, keywords, canonical injected from each view ── -->
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }
    else
    {
        <meta name="description" content="Strength Studio is the best gym in Belagavi with 750+ members, 5+ certified trainers & 50+ machines. Located at Kelkar Bagh Rd, Belagavi. Join today!" />
    }

    @if (ViewData["MetaKeywords"] != null)
    {
        <meta name="keywords" content="@ViewData["MetaKeywords"]" />
    }
    else
    {
        <meta name="keywords" content="gym in Belagavi, best gym Belgaum, fitness center Belagavi, personal trainer Belagavi, strength training Belagavi, gym membership Belagavi" />
    }

    @if (ViewData["CanonicalUrl"] != null)
    {
        <link rel="canonical" href="@ViewData["CanonicalUrl"]" />
    }
    else
    {
        <link rel="canonical" href="https://strengthstudio.in/" />
    }

    <!-- ── Open Graph per-page overrides ── -->
    <meta property="og:title" content="@(ViewData["OgTitle"] ?? ViewData["Title"] + " | Strength Studio Gym Belagavi")" />
    <meta property="og:description" content="@(ViewData["OgDescription"] ?? ViewData["MetaDescription"] ?? "Best gym in Belagavi with expert trainers, modern equipment & flexible hours. Join Strength Studio today!")" />
    <meta property="og:url" content="@(ViewData["CanonicalUrl"] ?? "https://strengthstudio.in/")" />
    <meta property="og:image" content="@(ViewData["OgImage"] ?? "https://strengthstudio.in/images/Gym-Equips/g1.jpg")" />
    <meta property="og:image:alt" content="@(ViewData["OgImageAlt"] ?? "Strength Studio Gym Belagavi main training floor")" />

    <!-- ── Twitter Card per-page ── -->
    <meta name="twitter:title" content="@(ViewData["OgTitle"] ?? ViewData["Title"] + " | Strength Studio Gym Belagavi")" />
    <meta name="twitter:description" content="@(ViewData["OgDescription"] ?? "Best gym in Belagavi with expert trainers, modern equipment & flexible hours. Join Strength Studio today!")" />
    <meta name="twitter:image" content="@(ViewData["OgImage"] ?? "https://strengthstudio.in/images/Gym-Equips/g1.jpg")" />

    <!-- ── Page Title ── -->
    <title>@ViewData["Title"] - Strength Studio Gym Belagavi</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/images/5x5ft (1).ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/5x5ft (1).ico" />

    <!-- ── Global LocalBusiness + HealthClub Schema (boosts Google local pack) ── -->
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": ["HealthClub", "LocalBusiness"],
          "@@id": "https://strengthstudio.in/#gym",
          "name": "Strength Studio Gym",
          "alternateName": ["Strength Studio", "Strength Studio Belgaum"],
          "description": "Strength Studio is Belagavi's premier gym with 750+ members, 5+ certified personal trainers and 50+ modern machines. We offer strength training, cardio, personal training and group fitness classes.",
          "url": "https://strengthstudio.in/",
          "logo": {
            "@@type": "ImageObject",
            "url": "https://strengthstudio.in/images/Gym-Equips/g1.jpg",
            "caption": "Strength Studio Gym Belagavi"
          },
          "image": [
            "https://strengthstudio.in/images/Gym-Equips/g1.jpg",
            "https://strengthstudio.in/images/Gym-Equips/g2.jpg",
            "https://strengthstudio.in/images/Gym-Equips/g3.jpg"
          ],
          "telephone": "+917090029156",
          "email": "info@strengthstudio.com",
          "address": {
            "@@type": "PostalAddress",
            "streetAddress": "1789/1, Kelkar Bagh Road",
            "addressLocality": "Belagavi",
            "addressRegion": "Karnataka",
            "postalCode": "590001",
            "addressCountry": "IN"
          },
          "geo": {
            "@@type": "GeoCoordinates",
            "latitude": 15.8497,
            "longitude": 74.4977
          },
          "hasMap": "https://maps.google.com/?q=Strength+Studio+Gym+Belagavi",
          "openingHoursSpecification": [
            {
              "@@type": "OpeningHoursSpecification",
              "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
              "opens": "05:30",
              "closes": "12:00"
            },
            {
              "@@type": "OpeningHoursSpecification",
              "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
              "opens": "16:00",
              "closes": "21:00"
            }
          ],
          "priceRange": "₹₹",
          "currenciesAccepted": "INR",
          "paymentAccepted": "Cash, UPI, Bank Transfer",
          "foundingDate": "2018",
          "areaServed": { "@@type": "City", "name": "Belagavi" },
          "amenityFeature": [
            { "@@type": "LocationFeatureSpecification", "name": "Modern Gym Equipment", "value": true },
            { "@@type": "LocationFeatureSpecification", "name": "Personal Training", "value": true },
            { "@@type": "LocationFeatureSpecification", "name": "Cardio Zone", "value": true },
            { "@@type": "LocationFeatureSpecification", "name": "Free Weights Area", "value": true },
            { "@@type": "LocationFeatureSpecification", "name": "Strength Training Zone", "value": true },
            { "@@type": "LocationFeatureSpecification", "name": "Functional Training Area", "value": true }
          ],
          "sameAs": [
            "https://www.instagram.com/strengthstudiobelgaum/"
          ]
        }
    </script>

    <!-- ── Per-page additional head content (schema, etc.) ── -->
    @RenderSection("Head", required: false)
</head>
<body>
    <!-- Mobile-first Navigation -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
            <div class="container">
                <!-- Brand -->
                <a class="navbar-brand d-flex align-items-center" href="@Url.Action("Index", "Home")">
                    <img src="~/images/5x5ft (1).ico" alt="Strength Studio Gym Belagavi logo" style="height: 40px; width: auto; margin-right: 10px;" />
                    <span class="d-none d-sm-inline fw-bold">Strength Studio</span>
                </a>

                <!-- Mobile Toggle Button -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navigation Menu -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
