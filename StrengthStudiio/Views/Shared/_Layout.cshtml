<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Strength Studio Gym</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
            <div class="container">
                <a class="navbar-brand fw-bold" href="@Url.Action("Index", "Home")">
                    @* <i class="fas fa-dumbbell text-warning"></i> *@
                    <img src="~/images/5x5ft (1).ico" />
                    Strength Studio
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Home")">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Services")">Services</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Trainers")">Trainers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "About")">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Membership")">Membership</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Contact")">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-warning text-dark ms-2 px-3" href="@Url.Action("Index", "Membership")">Join Now</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5><i class="fas fa-dumbbell text-warning"></i> Strength Studio Gym</h5>
                    <p class="text">Transform your body, transform your life. Join the fitness revolution today!</p>
                    <div class="social-links">
                        <a href="#" class="text-warning me-3"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="text-warning me-3"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-warning me-3"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-warning"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
                <div class="col-md-2">
                    <h6>Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="@Url.Action("Index", "Home")" class="">Home</a></li>
                        <li><a href="@Url.Action("Index", "Services")" class="">Services</a></li>
                        <li><a href="@Url.Action("Index", "Trainers")" class="">Trainers</a></li>
                        <li><a href="@Url.Action("Index", "About")" class="">About</a></li>
                        <li><a href="@Url.Action("Index", "Contact")" class="">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6>Contact Info</h6>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-map-marker-alt text-warning"></i> 123 Fitness Street, Bengaluru</li>
                        <li><i class="fas fa-phone text-warning"></i> +91 98765 43210</li>
                        <li><i class="fas fa-envelope text-warning"></i> info@Strength Studiogym.com</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6>Opening Hours</h6>
                    <ul class="list-unstyled">
                        <li>Monday - Friday: 5:00 AM - 11:00 PM</li>
                        <li>Saturday: 6:00 AM - 10:00 PM</li>
                        <li>Sunday: 7:00 AM - 9:00 PM</li>
                    </ul>
                </div>
            </div>
            <hr class="my-4">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0">&copy; 2025 Strength Studio Gym. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-end">
                    <a href="#" class="me-3">Privacy Policy</a>
                    <a href="#" class="">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>