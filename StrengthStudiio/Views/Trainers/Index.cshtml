@{
    ViewData["Title"] = "Trainers";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-white">Our Expert Trainers</h1>
                <p class="lead text-white">Meet our certified fitness professionals who will guide your journey</p>
            </div>
        </div>
    </div>
</section>

<!-- Trainers Section -->
<section class="py-5">
    <div class="container">
        <div class="row g-4 justify-content-center">

            <!-- Trainer 1 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Sameer Sutar</h4>
                        <p class="trainer-specialty">Head Trainer & Strength Coach</p>
                        <p class="trainer-description">
                            Lead trainer at Strength Studio with extensive experience in strength training and body transformation. Guides members from beginners to advanced athletes with precision and dedication.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">Strength Coach</span>
                            <span class="badge bg-warning text-dark">Body Transformation</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 2 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Rohit Patil</h4>
                        <p class="trainer-specialty">Strength & Conditioning</p>
                        <p class="trainer-description">
                            Certified personal trainer with 5+ years of experience in strength training and bodybuilding. Specializes in powerlifting and muscle building programs.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">ACMS Certified</span>
                            <span class="badge bg-warning text-dark">Nutrition Specialist</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 3 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Sushant Tippe</h4>
                        <p class="trainer-specialty">Functional Fitness & HIIT</p>
                        <p class="trainer-description">
                            Expert in functional training, HIIT, and athletic conditioning. Designs high-energy workout programs that improve overall fitness, endurance, and athletic performance.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">NSDC Certified</span>
                            <span class="badge bg-warning text-dark">Functional Training</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 4 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Tejas Gavali</h4>
                        <p class="trainer-specialty">Muscle Building & Nutrition</p>
                        <p class="trainer-description">
                            Specialized in hypertrophy training and structured nutrition planning. Helps members achieve lean muscle gains with science-backed programming and diet guidance.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">Certified Trainer</span>
                            <span class="badge bg-warning text-dark">Sports Nutritionist</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 5 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Shubham Pujari</h4>
                        <p class="trainer-specialty">Weight Loss & Cardio</p>
                        <p class="trainer-description">
                            Passionate about helping members lose weight and build stamina through structured cardio and circuit training. Known for motivating clients to push their limits safely and effectively.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">Certified Trainer</span>
                            <span class="badge bg-warning text-dark">Cardio Specialist</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Book Session Section -->
<section class="py-5 bg-warning">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h2 class="display-5 fw-bold text-dark">Ready to Train with Our Experts?</h2>
                <p class="lead text-dark mb-4">Book a personal training session and get customized guidance for your fitness goals.</p>
                <div class="row g-3 justify-content-center">
                    <div class="col-md-4">
                        <a href="@Url.Action("Index", "Contact")" class="btn btn-dark btn-lg w-100">
                            <i class="fas fa-calendar-alt"></i> Book Session
                        </a>
                    </div>
                    <div class="col-md-4">
                        <a href="@Url.Action("Index", "Contact")" class="btn btn-outline-dark btn-lg w-100">
                            <i class="fas fa-phone"></i> Call Us
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
