@{
    ViewData["Title"] = "Trainers";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-white">Our Expert Trainers</h1>
                <p class="lead text-white">Meet our certified fitness professionals who will guide your journey</p>
            </div>
        </div>
    </div>
</section>

<!-- Trainers Section -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <!-- Trainer 1 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Rajesh Kumar</h4>
                        <p class="trainer-specialty">Strength & Conditioning</p>
                        <p class="trainer-description">
                            Certified personal trainer with 8+ years of experience in strength training and bodybuilding. Specializes in powerlifting and muscle building programs.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">NASM Certified</span>
                            <span class="badge bg-warning text-dark">Nutrition Specialist</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 2 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Priya Sharma</h4>
                        <p class="trainer-specialty">Yoga & Pilates</p>
                        <p class="trainer-description">
                            Experienced yoga instructor with expertise in Hatha, Vinyasa, and Power Yoga. Helps clients improve flexibility, balance, and mindfulness.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">RYT 500</span>
                            <span class="badge bg-warning text-dark">Pilates Instructor</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 3 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Arjun Patel</h4>
                        <p class="trainer-specialty">HIIT & Cardio</p>
                        <p class="trainer-description">
                            High-energy trainer specializing in HIIT workouts, cardio training, and weight loss programs. Former athlete with a passion for functional fitness.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">ACSM Certified</span>
                            <span class="badge bg-warning text-dark">Sports Nutritionist</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 4 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Meera Reddy</h4>
                        <p class="trainer-specialty">Dance Fitness</p>
                        <p class="trainer-description">
                            Professional dance instructor specializing in Zumba, Bollywood dance fitness, and aerobics. Makes fitness fun and engaging for all ages.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">Zumba Licensed</span>
                            <span class="badge bg-warning text-dark">Dance Instructor</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 5 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Vikram Singh</h4>
                        <p class="trainer-specialty">Boxing & MMA</p>
                        <p class="trainer-description">
                            Former professional boxer with expertise in boxing, kickboxing, and mixed martial arts. Focuses on technique, conditioning, and self-defense.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">Boxing Coach</span>
                            <span class="badge bg-warning text-dark">MMA Instructor</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trainer 6 -->
            <div class="col-lg-4 col-md-6">
                <div class="trainer-card">
                    <div class="trainer-image">
                        <div class="placeholder-image">
                            <i class="fas fa-user fa-4x text-muted"></i>
                        </div>
                        <div class="trainer-overlay">
                            <div class="social-links">
                                <a href="#"><i class="fab fa-facebook-f"></i></a>
                                <a href="#"><i class="fab fa-instagram"></i></a>
                                <a href="#"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="trainer-info">
                        <h4>Sneha Gupta</h4>
                        <p class="trainer-specialty">Rehabilitation & Wellness</p>
                        <p class="trainer-description">
                            Physical therapist and wellness coach specializing in injury rehabilitation, corrective exercises, and senior fitness programs.
                        </p>
                        <div class="trainer-credentials">
                            <span class="badge bg-warning text-dark">Physical Therapist</span>
                            <span class="badge bg-warning text-dark">Corrective Exercise</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Book Session Section -->
<section class="py-5 bg-warning">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h2 class="display-5 fw-bold text-dark">Ready to Train with Our Experts?</h2>
                <p class="lead text-dark mb-4">Book a personal training session and get customized guidance for your fitness goals.</p>
                <div class="row g-3 justify-content-center">
                    <div class="col-md-4">
                        <a href="@Url.Action("Index", "Contact")" class="btn btn-dark btn-lg w-100">
                            <i class="fas fa-calendar-alt"></i> Book Session
                        </a>
                    </div>
                    <div class="col-md-4">
                        <a href="@Url.Action("Index", "Contact")" class="btn btn-outline-dark btn-lg w-100">
                            <i class="fas fa-phone"></i> Call Us
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>